Package: BigDataPE
Title: Secure and Intuitive Access to 'BigDataPE' 'API' Datasets
Version: 0.2.0
Date: 2026-06-26
Authors@R: c(
            person("André", "Leite", email = "leite@castlab.org", role = c("aut", "cre")),
            person("Hugo", "Vasconcelos", email = "hugo.vasconcelos@ufpe.br", role = "aut"),
